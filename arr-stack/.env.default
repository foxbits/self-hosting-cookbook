# Media sources for Movies (Radarr) - format: <local-folder>:<mounted-name>
MOVIES_MEDIA_SOURCES=/mnt/sda2/MULTIMEDIA:movies-e,/mnt/sda3/MULTIMEDIA:movies-f

# Media sources for TV Shows (Sonarr) - format: <local-folder>:<mounted-name>
SHOWS_MEDIA_SOURCES=/mnt/sda2/MULTIMEDIA:tv-e,/mnt/sda3/MULTIMEDIA:tv-f

# Timezone
TimeZone=Europe/Bucharest

# User permissions for the user running the stack
STACK_UID=1000
STACK_GID=1000

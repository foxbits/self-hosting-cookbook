#General settings
DEBUG=false
LIMITER_ENABLED=false

#Instance Name
SEARXNG_INSTANCE_NAME="My SearXNG"

# Public Instance URL
SEARXNG_BASE_URL=http://your-server:9704/

# Default locale for the UI
LOCALE=en
COUNTRY_CODE=US

# Secret key — change it with a random value
# e.g. generate it with  openssl rand -hex 32
SEARXNG_SECRET_KEY=CHANGE_ME_openssl_rand_hex_32

# Wolfram Alpha specific settings
WOLFRAM_DISABLED=true
WOLFRAM_API_KEY=YOUR_WOLFRAM_API_KEY

# CRAWL4AI Settings
MAX_CONCURRENT_TASKS=10

# GPT-Researcher Settings
# ----------------------
GPT_RESEARCHER_PATH=../../repos/better-gpt-researcher
LANGUAGE="english"

# LLM API Configuration
OPENAI_API_KEY=YOUR_API_KEY
OPENAI_BASE_URL=https://nano-gpt.com/api/v1

# LLM Models (OpenAI-compatible API Provider required)
FAST_LLM=openai:deepseek/deepseek-v4-flash
SMART_LLM=openai:deepseek/deepseek-v4-pro
STRATEGIC_LLM=openai:moonshotai/kimi-k2.6
EMBEDDING=openai:BAAI/bge-m3

# Sizing settings
MAX_SEARCH_RESULTS_PER_QUERY=10
MAX_ITERATIONS=3
MAX_SUBTOPICS=3
DEEP_RESEARCH_BREADTH=3
DEEP_RESEARCH_DEPTH=2
DEEP_RESEARCH_CONCURRENCY=5
MIN_RAW_CONTENT_LENGTH=300

# Scraper Configuration (bs, browser, nodriver, firecrawl, tavily_extract, crawl4ai)
SCRAPER=crawl4ai

# Crawl4AI API URL (for crawl4ai scraper - default: http://crawl4ai:11235)
CRAWL4AI_API_URL=http://crawl4ai:11235

# Image Generation
# ---------------
# Provider: "google" (official Google API) or "openai" (OpenAI-compatible)
IMAGE_GENERATION_PROVIDER=openai
IMAGE_GENERATION_ENABLED=false
IMAGE_GENERATION_MODEL=hidream
IMAGE_GENERATION_API_KEY=YOUR_API_KEY
IMAGE_GENERATION_BASE_URL=https://nano-gpt.com/api/v1
IMAGE_GENERATION_MAX_IMAGES=1


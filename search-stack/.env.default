#General settings
DEBUG=false
LIMITER_ENABLED=false

#Instance Name
SEARXNG_INSTANCE_NAME="My SearXNG"

# Public Instance URL
SEARXNG_BASE_URL=http://your-server:9704/

# Default locale for the UI
LOCALE=en
COUNTRY_CODE=US

# Secret key — change it with a random value
# e.g. generate it with  openssl rand -hex 32
SEARXNG_SECRET_KEY=CHANGE_ME_openssl_rand_hex_32

# Wolfram Alpha specific settings
WOLFRAM_DISABLED=true
WOLFRAM_API_KEY=YOUR_WOLFRAM_API_KEY

# CRAWL4AI Settings
MAX_CONCURRENT_TASKS=10

# GPT-Researcher Settings
# ----------------------
# LLM API Configuration
OPENAI_API_KEY=YOUR_API_KEY
OPENAI_BASE_URL=https://nano-gpt.com/api/v1

# Scraper Configuration (bs, browser, nodriver, firecrawl, tavily_extract, crawl4ai)
SCRAPER=crawl4ai

# Crawl4AI API URL (for crawl4ai scraper - default: http://crawl4ai:11235)
CRAWL4AI_API_URL=http://crawl4ai:11235

# Image Generation
# ---------------
# Provider: "google" (official Google API) or "openai" (OpenAI-compatible)
IMAGE_GENERATION_PROVIDER=openai
IMAGE_GENERATION_ENABLED=true

# Google API settings (when IMAGE_GENERATION_PROVIDER=google)
GOOGLE_API_KEY=
IMAGE_GENERATION_MODEL=models/gemini-2.0-flash-preview-image-generation

# OpenAI-compatible settings (when IMAGE_GENERATION_PROVIDER=openai)
IMAGE_API_KEY=YOUR_API_KEY
IMAGE_GENERATION_BASE_URL=https://nano-gpt.com/api/v1/images/generations
IMAGE_GENERATION_MODEL=qwen-image

IMAGE_GENERATION_MAX_IMAGES=3


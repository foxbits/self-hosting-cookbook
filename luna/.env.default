# ============================================
# OpenWebUI Configuration (luna stack)
# ============================================

# --- Data Directory (mapped to ./data on the local machine) ---
DATA_DIR=./data

# --- Tool Calling (Essentials) ---
ENABLE_TOOL_CALLING=True
DEFAULT_FUNCTION_CALLING_MODE=native   # Native mode recommended for modern models

# --- LLM Providers configuration ---
OPENAI_API_BASE_URL=https://nano-gpt.com/api/v1
OPENAI_API_KEY=YOUR_LLM_API_KEY
ENABLE_OLLAMA_API=false # Disable local Ollama (only use external providers)

# --- Model configuration ---
DEFAULT_MODELS=deepseek/deepseek-v4-pro # model for chat
TASK_MODEL_EXTERNAL=unsloth/gemma-3-4b-it # model for non-chat easy tasks (e.g., follow-up generation, title generation), needs to be fast and cost-effective
ENABLE_AUTOCOMPLETE_GENERATION=True
ENABLE_FOLLOW_UP_GENERATION=True
ENABLE_TITLE_GENERATION=True
ENABLE_BASE_MODELS_CACHE=True
MODELS_CACHE_TTL=300

# --- RAG / Embeddings ---
RAG_EMBEDDING_ENGINE=openai
RAG_OPENAI_API_BASE_URL=${OPENAI_API_BASE_URL}
RAG_OPENAI_API_KEY=${OPENAI_API_KEY}
RAG_EMBEDDING_MODEL=BAAI/bge-m3

# --- Image Generation (OpenAI compatible API) ---
ENABLE_IMAGE_GENERATION=True
IMAGE_GENERATION_ENGINE=openai
IMAGE_GENERATION_MODEL=hidream
ENABLE_IMAGE_EDIT=true
IMAGE_EDIT_MODEL=qwen-image
IMAGES_OPENAI_API_BASE_URL=https://nano-gpt.com/api/v1 # OpenAI compatible API
IMAGES_OPENAI_API_KEY=image_generation_api_key
IMAGES_EDIT_OPENAI_API_BASE_URL=https://nano-gpt.com/api/v1 # OpenAI compatible API
IMAGES_EDIT_OPENAI_API_KEY=images_edit_api_key

# --- Memory System, Database && Vector Database ---
ENABLE_MEMORIES=True
VECTOR_DB=pgvector
DATABASE_TYPE=postgresql
POSTGRES_USER=postgres
POSTGRES_PASSWORD=strong-password-goes-here

# --- Redis / Valkey ---
REDIS_URL=redis://datastore-memory:6379/0

# --- WebUI Customization ---
WEBUI_NAME=Your-Instance-Name
WEBUI_URL=https://your-instance.your-site.net
DEFAULT_LOCALE=en

# --- AUTH Settings ---
WEBUI_SECRET_KEY=CHANGE_ME_generated_secret_key
ENABLE_API_KEYS=True # Allow users to create API keys for external access

# Disable user registration (admin will create user accounts manually, security)
ENABLE_SIGNUP=False

# Default user authentication with username/password (can be used for initial setup, but recommend switching to OAuth SSO for better security and user management)
ENABLE_PASSWORD_AUTH=False              # Disable password login, only allow OAuth (more secure and easier to manage)
ENABLE_LOGIN_FORM=False                 # Disable the login form, only show "Login with OAuth" button
ENABLE_PASSWORD_CHANGE_FORM=False       # Disable password change form since password auth is disabled

# OAuth / OpenID Connect Settings (for SSO integration, e.g., with Keycloak, Auth0, etc.)
ENABLE_OAUTH_SIGNUP=True
OAUTH_CLIENT_ID=YOUR_OAUTH_CLIENT_ID
OAUTH_CLIENT_SECRET=YOUR_OAUTH_CLIENT_SECRET
OPENID_PROVIDER_URL=https://auth.yoursite.net/<tenant-id>/.well-known/openid-configuration
OAUTH_PROVIDER_NAME=yoursite.net
OPENID_REDIRECT_URI=https://your-instance.your-site.net/oauth/oidc/callback
